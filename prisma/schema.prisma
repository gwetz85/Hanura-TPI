generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  role      String   // ADMIN, DPC, PAC_BARAT, PAC_KOTA, PAC_TIMUR, PAC_BUKIT_BESTARI
  phone     String?  // PAC contact number (optional)
  name      String

  ktaRequests          ProspectiveMember[]
  activitySuggestions  ActivitySuggestion[]
  members              Member[]
  activityComments     ActivityComment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProspectiveMember {
  id          String   @id @default(cuid())
  pacId       String
  pac         User     @relation(fields: [pacId], references: [id])
  name        String
  nik         String
  address     String
  phone       String
  photoKtpUrl String?
  ktpVerified Boolean @default(false)
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ActivitySuggestion {
  id           String   @id @default(cuid())
  pacId        String
  pac          User     @relation(fields: [pacId], references: [id])
  title        String
  description  String
  date         DateTime?
  time         String?
  location     String?
  activityType String?
  reply        String?
  status       String   @default("PENDING") // PENDING, BATAL, SEDANG_BERLANGSUNG, SELESAI

  isReadByDpc  Boolean  @default(false)
  isReadByPac  Boolean  @default(false)
  creatorRole  String   @default("PAC") // PAC, DPC

  comments     ActivityComment[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ActivityComment {
  id           String             @id @default(cuid())
  suggestionId String
  suggestion   ActivitySuggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  authorId     String
  author       User               @relation(fields: [authorId], references: [id])
  message      String
  createdAt    DateTime           @default(now())
}

model Member {
  id            String   @id @default(cuid())
  pacId         String
  pac           User     @relation(fields: [pacId], references: [id])
  noUrut        Int?
  nomorKta      String?
  name          String
  nik           String?
  phone         String?
  gender        String?
  birthPlace    String?
  birthDate     String?
  agama         String?
  maritalStatus String?
  jobStatus     String?
  address       String?
  village       String?
  subDistrict   String?
  isVerified    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BoardMember {
  id        String   @id @default(cuid())
  level     String
  position  String
  name      String
  ktaNumber String?
  nik       String?
  nomorSk   String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IncomingLetter {
  id               String   @id @default(cuid())
  tanggalSurat     String
  nomorSurat       String
  instansiPengirim String
  perihal          String
  fileUrl          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model OutgoingLetter {
  id               String   @id @default(cuid())
  tanggalSurat     String
  nomorSurat       String
  penerima         String
  perihal          String
  fileUrl          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model BoardSK {
  id        String   @id @default(cuid())
  level     String   @unique // DPD, DPC, PAC BARAT, etc.
  fileUrl   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
